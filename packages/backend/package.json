{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#app/*": "./dist/app/*",
    "#config/*": "./dist/config/*",
    "#vendor/*": "./dist/vendor/*",
    "#database/*": "./dist/database/*",
    "#logger": "./dist/vendor/utils/logger.js",
    "#drizzle/*": "./dist/drizzle/*"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist .tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "db:create": "tsx src/db/create-database.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:shared-study-audio": "pnpm db:migrate && pnpm db:backfill-study-audio",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "db:backfill-study-audio": "tsx src/scripts/backfill-study-audio.ts",
    "mail:test": "tsx src/scripts/send-test-email.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/xai": "^3.0.59",
    "@arktype/type": "2.2.0",
    "@mistralai/mistralai": "^1.14.1",
    "@sentry/node": "^10.51.0",
    "ai": "^6.0.101",
    "arctic": "^3.7.0",
    "better-result": "^2.9.2",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "ioredis": "^5.3.2",
    "luxon": "^3.4.4",
    "metautil": "^5.2.0",
    "minio": "8.0.7",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.7",
    "openai": "^6.32.0",
    "pg": "^8.20.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "shared": "workspace:*",
    "ts-pattern": "^5.6.0",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.56.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/luxon": "^3.7.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^10.0.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.5.14",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.19.2",
    "tsxp": "^1.1.5",
    "vitest": "^2.1.8"
  }
}
