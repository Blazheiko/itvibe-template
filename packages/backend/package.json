{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "imports": {
    "#app/*": "./dist/app/*",
    "#config/*": "./dist/config/*",
    "#vendor/*": "./dist/vendor/*",
    "#database/*": "./dist/database/*",
    "#logger": "./dist/vendor/utils/logger.js",
    "#drizzle/*": "./dist/drizzle/*"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist .tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "db:create": "tsx src/db/create-database.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed.ts",
    "mail:test": "tsx src/scripts/send-test-email.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/xai": "3.0.88",
    "@arktype/type": "2.2.0",
    "@mistralai/mistralai": "2.2.1",
    "@sentry/node": "10.51.0",
    "ai": "6.0.184",
    "arctic": "3.7.0",
    "better-result": "2.9.2",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "ioredis": "5.10.1",
    "luxon": "3.7.2",
    "metautil": "5.5.2",
    "minio": "8.0.7",
    "nanoid": "5.1.11",
    "nodemailer": "8.0.7",
    "openai": "6.38.0",
    "pg": "8.21.0",
    "pino": "10.3.1",
    "pino-pretty": "10.3.1",
    "shared": "workspace:*",
    "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.56.0",
    "web-push": "3.6.7",
    "ws": "8.20.1"
  },
  "devDependencies": {
    "@types/luxon": "^3.7.1",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.30.6",
    "tsx": "^4.22.2",
    "typescript": "6.0.3",
    "vitest": "^2.1.9"
  }
}
