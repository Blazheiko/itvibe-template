APP_NAME=uwebsockets-api
APP_KEY=
APP_ENV=local
# Explicit production classifier for security-sensitive fail-fast checks.
# Leave empty in local/dev if APP_ENV naming is reliable.
# Set to true in any production-like deployment, even if APP_ENV uses a custom
# value such as "prod-eu", "live", "prd", or "staging-prod".
# Production deploy manifests / Docker / Helm values should set this explicitly.
APP_IS_PRODUCTION=false
APP_URL=http://localhost:3000
## Public frontend app URL used in user-facing links (for example email verification pages).
FRONTEND_URL=http://localhost:5173
# Public frontend URL used for referral links.
LANDING_URL=http://localhost:5173
PORT=3000
HOST=0.0.0.0
DOMAIN=127.0.0.1
UNIX_PATH=
ENABLED_CORS=true
CREDENTIONALS_CORS=false

SERVE_STATIC=true
DOC_PAGE=true

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/itvibe_template"

DB_CONNECTION="pg"
PGSQL_HOST=127.0.0.1
PGSQL_PORT=5432
PGSQL_USER=postgres
PGSQL_PASSWORD=postgres
PGSQL_DB_NAME=itvibe_template

SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_IGNORE_TLS=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_REPLY_TO=

CDN_URL=

REDIS_HOST="127.0.0.1"
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_PREFIX="promo_designer:"

VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:example@gmail.com"
# Comma-separated whitelist of origins allowed for cross-origin requests.
# No wildcards — list full origins. Empty means no cross-origin access.
# Example: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=
# CSRF starts in report-only mode by default. Set true only after observing
# report-only logs for current clients.
CSRF_ENFORCE=false
# Comma-separated list of exact origins allowed by CSRF Origin/Referer checks.
# Empty allows any origin for the secondary check; token validation remains active
# when CSRF_ENFORCE=true.
CSRF_ALLOWED_ORIGINS=
# Optional hardening: reject unsafe requests that have neither Origin nor Referer.
# Can break older webviews / embedded contexts; keep false unless explicitly tested.
CSRF_STRICT_ORIGIN=false
# Enable the __Host- prefix on the session cookie. Requires HTTPS and APP_URL
# starting with https:// — the server refuses to start otherwise.
# Defaults to APP_IS_PRODUCTION; set explicitly for staging/preview environments.
SESSION_COOKIE_HOST_PREFIX=false
# Trust X-Forwarded-For / X-Real-IP only when requests arrive through a trusted
# proxy or load balancer. Keep false unless you explicitly run behind one.
TRUST_PROXY=false
# Comma-separated exact IPs or CIDRs for ingress proxies allowed to supply
# forwarded client IP headers. Example: 10.0.0.0/8,192.168.1.10/32
# Expected proxy behavior: append to X-Forwarded-For and keep origin reachable
# only through trusted proxies/load balancers.
TRUSTED_PROXY_CIDRS=

# Auth / phone verification feature flags
# Requires email confirmation before email registration returns an authenticated session.
# Set false to authenticate new email users immediately and let them confirm email later.
AUTH_STRICT_REGISTRATION=true
# Enables login/register/link/reset phone flows.
AUTH_PHONE_ENABLED=false
# Backend SMS provider selector.
# Supported today:
# - unsupported : safe default, phone flows fail closed
# - fake        : local/test only, deterministic code from AUTH_FAKE_SMS_CODE
AUTH_SMS_PROVIDER=unsupported
# Optional dedicated secret for HMAC hashing SMS verification codes at rest.
# If empty, APP_KEY is used instead. Must be at least 32 characters when phone
# auth is enabled.
AUTH_OTP_HMAC_KEY=
# Explicit override required before fake SMS provider can start.
AUTH_SMS_PROVIDER_ALLOW_FAKE=false
# Required when AUTH_SMS_PROVIDER=fake. Must be set explicitly even in local/test.
# Demo/dev-only value below; do not use fake provider in production-like environments.
AUTH_FAKE_SMS_CODE=123456
# Challenge lifetime in seconds for SMS registration/link/reset flows.
AUTH_SMS_CHALLENGE_TTL_SECONDS=600
# Minimum wait before requesting another SMS for the same flow/phone.
AUTH_SMS_RESEND_COOLDOWN_SECONDS=60
# Per-challenge invalid confirmation attempts before the challenge is invalidated.
AUTH_SMS_MAX_INVALID_ATTEMPTS=5
# Per-IP confirm attempts per hour for SMS code confirmation endpoints.
AUTH_SMS_MAX_CONFIRM_ATTEMPTS_PER_IP_PER_HOUR=20
# Cross-flow SMS send budget per phone number per hour.
AUTH_SMS_MAX_SENDS_PER_PHONE_PER_HOUR=3
# Per-IP SMS start/send budget per hour.
AUTH_SMS_MAX_SENDS_PER_IP_PER_HOUR=10
# Generic email registration throttle: per-target email budget per hour.
AUTH_EMAIL_REGISTER_MAX_ATTEMPTS_PER_EMAIL_PER_HOUR=3
# Generic email registration throttle: per-IP budget per hour.
AUTH_EMAIL_REGISTER_MAX_ATTEMPTS_PER_IP_PER_HOUR=10
# Email-link throttle: sends per target email per hour.
AUTH_EMAIL_LINK_MAX_ATTEMPTS_PER_TARGET_PER_HOUR=3
# Email-link throttle: sends per authenticated user per hour.
AUTH_EMAIL_LINK_MAX_ATTEMPTS_PER_USER_PER_HOUR=3
# Email-link minimum interval between repeated sends by the same user.
AUTH_EMAIL_LINK_COOLDOWN_SECONDS=60

S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_PREFIX=app
S3_STATIC_DATA_PREFIX=public
S3_DYNAMIC_DATA_PREFIX=uploads

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SENTRY_DSN=
SENTRY_ENABLED=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini
OPENAI_CHAT_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

XAI_API_KEY=
XAI_CHAT_MODEL=grok-4-1-fast-non-reasoning
XAI_IMAGE_API_URL=https://api.x.ai/v1/images/generations
XAI_IMAGE_EDIT_API_URL=https://api.x.ai/v1/images/edits
XAI_IMAGE_MODEL=grok-imagine-image
XAI_IMAGE_FORMAT=base64
